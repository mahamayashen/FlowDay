# Copy this to .env and fill in your values. Never commit .env.

# Server
PORT=5060

# Database (PostgreSQL via Docker)
DATABASE_URL=postgresql+asyncpg://flowday:flowday@localhost:5432/flowday

# Cache (Redis via Docker)
REDIS_URL=redis://localhost:6379/0

# Security — generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-me-in-production

# OAuth — Google (optional — leave blank to disable)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:5060/auth/google/callback

# OAuth — GitHub (optional — leave blank to disable)
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_REDIRECT_URI=http://localhost:5060/auth/github/callback

# Monitoring (optional — leave blank to disable Sentry)
SENTRY_DSN=
PROMETHEUS_ENABLED=true
